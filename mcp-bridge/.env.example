# ═══════════════════════════════════════════════════════════════
# MCP Bridge Server - Environment Configuration
# ═══════════════════════════════════════════════════════════════

# Server Configuration
PORT=3456
NODE_ENV=development
LOG_LEVEL=info

# MCP Servers Base Path
MCP_SERVERS_PATH=/Users/azzedinezazai/Documents/Agency-Killer-V4/mcp-servers

# Google Cloud Configuration (for Nano Banana Pro, VEO3)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Meta Ads Configuration
META_ACCESS_TOKEN=your-meta-access-token
META_AD_ACCOUNT_ID=your-ad-account-id

# Google Ads Configuration
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=your-customer-id

# GTM Configuration
GTM_CONTAINER_ID=your-container-id

# Looker Configuration
LOOKER_BASE_URL=your-looker-base-url
LOOKER_CLIENT_ID=your-client-id
LOOKER_CLIENT_SECRET=your-client-secret

# LUNA Configuration (SEO & Keyword Research)
GOOGLE_API_KEY=your-google-api-key-for-pagespeed-and-trends

# Cloudinary Configuration (MILO - Image CDN Storage)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
