# ═══════════════════════════════════════════════════════════════
# THE HIVE OS V4 - Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ─────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# For Supabase Edge Functions (set in Supabase Dashboard → Edge Functions → Secrets)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────────
# Stripe Configuration
# Get these from: https://dashboard.stripe.com/apikeys
# ─────────────────────────────────────────────────────────────────

# Public key (starts with pk_test_ or pk_live_)
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Secret key (starts with sk_test_ or sk_live_) - NEVER commit this!
# Set this in Supabase Dashboard → Edge Functions → Secrets
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret (starts with whsec_) - Get from Stripe Webhooks dashboard
# Set this in Supabase Dashboard → Edge Functions → Secrets
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe Products
# Create products in Stripe Dashboard → Products → Add product
# Then copy the Price ID (starts with price_)
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# ─────────────────────────────────────────────────────────────────
# Application URLs
# ─────────────────────────────────────────────────────────────────

# Your app URL (for Stripe redirects and webhooks)
# Development: http://localhost:5173
# Production: https://your-domain.com
APP_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────
# Backend Configuration (V5 TypeScript Backend)
# ─────────────────────────────────────────────────────────────────

# TypeScript Backend API URL (replaces n8n webhooks in V5)
# Development: http://localhost:3457
# Production: https://api.your-domain.com
VITE_BACKEND_API_URL=http://localhost:3457

# Enable debug logging for API calls (development only)
VITE_DEBUG_API=false

# ─────────────────────────────────────────────────────────────────
# n8n Workflow Configuration (LEGACY - V4 only)
# Will be deprecated once V5 migration is complete
# ─────────────────────────────────────────────────────────────────

VITE_N8N_WEBHOOK_GENESIS=https://your-n8n-instance.com/webhook/genesis
VITE_N8N_WEBHOOK_CHAT=https://your-n8n-instance.com/webhook/chat
VITE_DEBUG_N8N=false

# ─────────────────────────────────────────────────────────────────
# Google Cloud (for n8n agents with Vertex AI)
# ─────────────────────────────────────────────────────────────────

GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/credentials.json

# ─────────────────────────────────────────────────────────────────
# Cloudinary Configuration (for support ticket screenshots)
# Get these from: https://console.cloudinary.com/settings
# ─────────────────────────────────────────────────────────────────

# Your cloud name (found in Cloudinary Dashboard)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Upload preset (create an unsigned preset in Settings → Upload)
# Must be set to "Unsigned" mode
VITE_CLOUDINARY_UPLOAD_PRESET=unsigned-preset-name

# ─────────────────────────────────────────────────────────────────
# SendGrid Configuration (Phase 2 - Email Notifications)
# Get these from: https://app.sendgrid.com/settings/api_keys
# ─────────────────────────────────────────────────────────────────

# SendGrid API Key (starts with SG.) - NEVER commit this!
# Create a new API key in SendGrid Dashboard → Settings → API Keys
# Required permissions: Mail Send (Full Access)
# Set this in Supabase Dashboard → Edge Functions → Secrets
SENDGRID_API_KEY=SG.your-api-key

# From email address (must be verified in SendGrid)
# Verify in: SendGrid Dashboard → Settings → Sender Authentication
SENDGRID_FROM_EMAIL=support@your-domain.com
SENDGRID_FROM_NAME=Your App Support
