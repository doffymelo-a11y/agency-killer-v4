# ═══════════════════════════════════════════════════════════════
# THE HIVE OS V5 - Backend Environment Variables
# ═══════════════════════════════════════════════════════════════

# Server Configuration
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MCP Bridge
MCP_BRIDGE_URL=http://localhost:3456

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# OpenAI API (fallback)
OPENAI_API_KEY=sk-your-openai-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_FREE=10
RATE_LIMIT_MAX_PRO=60
RATE_LIMIT_MAX_ENTERPRISE=300

# Security
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_SECRET=your-jwt-secret

# Logging
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────
# Telegram Bot (Phase 1-3)
# ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_SECRET_TOKEN=your-secret-token
TELEGRAM_WEBHOOK_URL=https://your-tunnel.loca.lt/api/telegram/webhook

# Founder User ID (super admin who receives Telegram notifications)
# SECURITY: NEVER hardcode this in the code - always use env var
FOUNDER_USER_ID=your-founder-user-uuid

# ─────────────────────────────────────────────────────────────────
# Claude Agent SDK (Phase 4 - Hive Doctor Auto-Fix)
# ─────────────────────────────────────────────────────────────────
# Separate Anthropic API key for Hive Doctor (for cost tracking and cap)
HIVE_DOCTOR_ANTHROPIC_KEY=sk-ant-your-separate-api-key

# Agent timeout in milliseconds (10 minutes default)
CLAUDE_AGENT_TIMEOUT_MS=600000

# Max cost per fix session in USD (hard cap to prevent runaway costs)
CLAUDE_AGENT_MAX_COST_USD=5.0

# Path to the git repository for agent to work in
CLAUDE_AGENT_REPO_PATH=/path/to/your/cockpit

# GitHub token for creating PRs via gh CLI
GITHUB_TOKEN=ghp_your-github-token
