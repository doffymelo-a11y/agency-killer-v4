# ═══════════════════════════════════════════════════════════════
# THE HIVE OS V4 - Git Ignore
# Professional .gitignore for security and clean repo
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# 🔐 SECRETS & CREDENTIALS (CRITICAL - NEVER COMMIT!)
# ─────────────────────────────────────────────────────────────────

# Environment variables
.env
.env.local
.env.production
.env.*.local

# Credentials
Credentials/
*.pem
*.key
*.p12
*.pfx
*.json.secret
*-credentials.json
service-account*.json

# API Keys & Tokens
.stripe/
.supabase/
*.secret
*.token

# ─────────────────────────────────────────────────────────────────
# 📦 Dependencies
# ─────────────────────────────────────────────────────────────────

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Package managers
.pnpm-store/
.yarn/
.npm/

# ─────────────────────────────────────────────────────────────────
# 🏗️ Build & Distribution
# ─────────────────────────────────────────────────────────────────

# Vite
dist/
dist-ssr/
*.local

# Build outputs
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/

# TypeScript
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────
# 🧪 Testing & Coverage
# ─────────────────────────────────────────────────────────────────

coverage/
*.coverage
.nyc_output/
.pytest_cache/
__pycache__/

# ─────────────────────────────────────────────────────────────────
# 📝 Logs & Temporary Files
# ─────────────────────────────────────────────────────────────────

logs/
*.log
*.log.*
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────
# 💻 IDE & Editor
# ─────────────────────────────────────────────────────────────────

# VSCode
.vscode/
*.code-workspace

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# ─────────────────────────────────────────────────────────────────
# 🖥️ OS Files
# ─────────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini

# Linux
*~
.directory
.Trash-*

# ─────────────────────────────────────────────────────────────────
# 🚀 Deployment & Services
# ─────────────────────────────────────────────────────────────────

# Vercel
.vercel/
.vercel

# Netlify
.netlify/

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log

# Supabase (local dev)
.supabase/
supabase/.temp/

# Docker
.dockerignore

# ─────────────────────────────────────────────────────────────────
# 📊 Database & Data
# ─────────────────────────────────────────────────────────────────

# SQLite
*.sqlite
*.sqlite3
*.db

# PostgreSQL dumps
*.dump
*.sql.gz

# ─────────────────────────────────────────────────────────────────
# 🎨 Assets (Large Files - Use Git LFS if needed)
# ─────────────────────────────────────────────────────────────────

# Uncomment if you want to exclude large media files
# *.mp4
# *.mov
# *.avi
# *.psd
# *.sketch

# ─────────────────────────────────────────────────────────────────
# 🧹 Project-Specific
# ─────────────────────────────────────────────────────────────────

# Temporary migration scripts
apply-migration-*.js
scripts/temp-*.js

# Backup files
*.backup
*.bak
*.old

# Test outputs
test-output/
playwright-report/
test-results/

# ─────────────────────────────────────────────────────────────────
# ✅ KEEP These Files (Don't Ignore)
# ─────────────────────────────────────────────────────────────────

# Keep example env files (for documentation)
!.env.example

# Keep workflow JSONs (n8n)
!agents/**/*.workflow.json

# Keep migration files
!cockpit/supabase/migrations/*.sql
!supabase/migrations/*.sql

# Keep documentation
!*.md
!README.md
!CHANGELOG.md

# Keep config files
!package.json
!tsconfig.json
!vite.config.ts
!tailwind.config.js
!postcss.config.js

# ═══════════════════════════════════════════════════════════════
# End of .gitignore
# ═══════════════════════════════════════════════════════════════
