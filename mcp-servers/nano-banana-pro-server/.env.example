# Google Cloud Configuration for Imagen 3
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_LOCATION=us-central1

# Notes:
# - GOOGLE_APPLICATION_CREDENTIALS should point to a service account JSON with Vertex AI permissions
# - GOOGLE_CLOUD_LOCATION can be: us-central1, europe-west4, asia-southeast1
# - Requires Vertex AI API enabled in your GCP project
